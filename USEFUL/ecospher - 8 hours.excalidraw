      "seed": 1266416813,
      "version": 4,
      "versionNonce": 1158800221,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783514742346,
      "link": null,
      "locked": false,
      "text": "•  Single nav list replaces the earlier icon-rail + module-tree split — one less layer to parse\n•  Active page highlighted with solid moss background, not just a thin accent line\n•  Live counts inline (Environmental 214, Governance 3, Gamification 12) so nothing needs a click to check\n•  Sidebar footer always shows the signed-in user's name, department and current Level/XP — gamification is visible everywhere, not just on one screen\n•  Placeholder modules (Social, Governance) still appear in nav for full ERP scope, but link to a simple “build this out next” screen rather than a half-finished one",
      "fontSize": 11.8,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 69.75,
      "containerId": null,
      "originalText": "•  Single nav list replaces the earlier icon-rail + module-tree split — one less layer to parse\n•  Active page highlighted with solid moss background, not just a thin accent line\n•  Live counts inline (Environmental 214, Governance 3, Gamification 12) so nothing needs a click to check\n•  Sidebar footer always shows the signed-in user's name, department and current Level/XP — gamification is visible everywhere, not just on one screen\n•  Placeholder modules (Social, Governance) still appear in nav for full ERP scope, but link to a simple “build this out next” screen rather than a half-finished one",
      "lineHeight": 1.25,
      "index": "aqV",
      "autoResize": true
    },
