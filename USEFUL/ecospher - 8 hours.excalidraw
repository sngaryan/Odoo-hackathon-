    {
      "id": "aoum7oese3zqgep2",
      "type": "text",
      "x": 2506,
      "y": 360,
      "width": 1424,
      "height": 73.75,
      "angle": 0,
      "strokeColor": "#33403a",
      "backgroundColor": "transparent",
