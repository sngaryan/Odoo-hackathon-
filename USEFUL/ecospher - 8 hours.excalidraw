    },
    {
      "id": "061o0xwm1gtok5nn",
      "type": "text",
      "x": 2070,
      "y": 4030,
      "width": 1860,
      "height": 73.75,
      "angle": 0,
      "strokeColor": "#33403a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 747125566,
      "version": 3,
      "versionNonce": 22151507,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783514720917,
      "link": null,
      "locked": false,
      "text": "•  Easy-difficulty challenges can be configured to auto-approve (skip the diamond) — everything Medium and above always needs admin review\n•  A rejection always routes back to “Proof Submitted”, never to “Joined” — the employee doesn't lose their spot in the challenge\n•  XP payout = base XP for the difficulty × any active bonus (streak, department catch-up, early-bird) configured in Settings\n•  Badge and level checks run automatically after every XP award — they are a consequence of XP, not a separate manual step\n•  Leaderboard and Dashboard are the last step, not a live query — they refresh from the same event so numbers never disagree",
      "fontSize": 11.8,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 69.75,
      "containerId": null,
      "originalText": "•  Easy-difficulty challenges can be configured to auto-approve (skip the diamond) — everything Medium and above always needs admin review\n•  A rejection always routes back to “Proof Submitted”, never to “Joined” — the employee doesn't lose their spot in the challenge\n•  XP payout = base XP for the difficulty × any active bonus (streak, department catch-up, early-bird) configured in Settings\n•  Badge and level checks run automatically after every XP award — they are a consequence of XP, not a separate manual step\n•  Leaderboard and Dashboard are the last step, not a live query — they refresh from the same event so numbers never disagree",
      "lineHeight": 1.25,
      "index": "b3t",
      "autoResize": true
    },
