generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ESG_MANAGER
  EMPLOYEE
  AUDITOR
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  users               User[]
  carbonTransactions  CarbonTransaction[]
  environmentalGoals  EnvironmentalGoal[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model User {
  id                     String                @id @default(cuid())
  name                   String
  email                  String                @unique
  passwordHash           String
  role                   Role
  departmentId           String?
  department             Department?           @relation(fields: [departmentId], references: [id])
  xp                     Int                   @default(0)
  participations         CsrParticipation[]
  createdActivities      CsrActivity[]         @relation("ActivityCreator")
  submissions            ChallengeSubmission[]
  badges                 UserBadge[]
  approvedSubmissions    ChallengeSubmission[] @relation("SubmissionAuditor")
  approvedParticipations CsrParticipation[]   @relation("ParticipationAuditor")
  carbonTransactions     CarbonTransaction[]
  policyAcknowledgements PolicyAcknowledgement[]
  ownedIssues            ComplianceIssue[]     @relation("IssueOwner")
  reports                ReportRun[]
  proofEvidence          ProofEvidence[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model CsrActivity {
  id                String             @id @default(cuid())
  title             String
  description       String
  date              DateTime
  location          String
  volunteeringHours Float
  xpReward          Int                @default(100)
  creatorId         String
  creator           User               @relation("ActivityCreator", fields: [creatorId], references: [id])
  participations    CsrParticipation[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model CsrParticipation {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  activityId   String
  activity     CsrActivity @relation(fields: [activityId], references: [id])
  status       String      // "REGISTERED" | "PENDING_APPROVAL" | "APPROVED" | "REJECTED"
  proofText    String?
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?
  approvedBy   User?       @relation("ParticipationAuditor", fields: [approvedById], references: [id])
  evidence     ProofEvidence[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([userId, activityId])
}

model Challenge {
  id            String                @id @default(cuid())
  title         String
  description   String
  type          String                // "COMMUTE" | "ENERGY" | "WASTE" | "WATER" | "OTHER"
  xpReward      Int                   @default(50)
  badgeRewardId String?
  badgeReward   Badge?                @relation(fields: [badgeRewardId], references: [id])
  startDate     DateTime
  endDate       DateTime
  submissions   ChallengeSubmission[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ChallengeSubmission {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id])
  status       String    // "SUBMITTED" | "APPROVED" | "REJECTED"
  proofText    String
  reviewFeedback String?
  submittedAt  DateTime  @default(now())
  approvedAt   DateTime?
  approvedById String?
  approvedBy   User?     @relation("SubmissionAuditor", fields: [approvedById], references: [id])
  evidence     ProofEvidence[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, challengeId])
}

model ProofEvidence {
  id              String               @id @default(cuid())
  storagePath     String
  originalName    String
  mimeType        String
  sizeBytes       Int
  participationId String?
  participation   CsrParticipation?    @relation(fields: [participationId], references: [id], onDelete: Cascade)
  submissionId    String?
  submission      ChallengeSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  uploadedById    String
  uploadedBy      User                 @relation(fields: [uploadedById], references: [id])
  createdAt       DateTime             @default(now())
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String      // e.g. "commute", "energy", "volunteering", "first-step"
  xpThreshold Int         @default(0) // earned automatically when reaching this XP, or manually rewarded
  challenges  Challenge[]
  userBadges  UserBadge[]
  createdAt   DateTime    @default(now())
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Policy {
  id String @id @default(cuid())
  title String
  version String
  summary String
  status PolicyStatus @default(DRAFT)
  publishedAt DateTime?
  acknowledgements PolicyAcknowledgement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([title, version])
}

model PolicyAcknowledgement {
  id String @id @default(cuid())
  userId String
  policyId String
  acknowledgedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  @@unique([userId, policyId])
}

model Audit {
  id String @id @default(cuid())
  title String
  scope String
  auditDate DateTime
  auditorId String
  status AuditStatus @default(PLANNED)
  issues ComplianceIssue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceIssue {
  id String @id @default(cuid())
  auditId String?
  title String
  description String
  severity IssueSeverity
  status IssueStatus @default(OPEN)
  ownerId String?
  openedAt DateTime @default(now())
  resolvedAt DateTime?
  audit Audit? @relation(fields: [auditId], references: [id], onDelete: SetNull)
  owner User? @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status, severity])
}

model ReportRun {
  id String @id @default(cuid())
  userId String
  type String
  filters Json
  format String
  filePath String?
  generatedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmissionFactor {
  id           String              @id @default(cuid())
  name         String
  category     String
  unit         String
  factorKgCo2e Decimal
  active       Boolean             @default(true)
  transactions CarbonTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CarbonTransaction {
  id                  String         @id @default(cuid())
  departmentId        String
  factorId            String
  createdById         String
  source              String
  description         String
  quantity            Decimal
  factorValueSnapshot Decimal
  calculatedKgCo2e    Decimal
  occurredOn          DateTime
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  department     Department     @relation(fields: [departmentId], references: [id])
  emissionFactor EmissionFactor @relation(fields: [factorId], references: [id])
  createdBy      User           @relation(fields: [createdById], references: [id])

  @@index([occurredOn, departmentId])
}

model EnvironmentalGoal {
  id            String   @id @default(cuid())
  departmentId  String
  name          String
  targetKgCo2e  Decimal
  currentKgCo2e Decimal
  deadline      DateTime
  status        String   // e.g., ON_TRACK, AT_RISK, COMPLETED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
}
